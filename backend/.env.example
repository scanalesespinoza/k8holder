# Backend Configuration
PORT=8080
NODE_ENV=development

# Kubernetes Configuration
# When running in-cluster, these are auto-detected
# When running locally, point to your kubeconfig
KUBECONFIG_PATH=~/.kube/config

# Namespace to monitor (comma-separated for multiple)
# Leave empty for all namespaces
NAMESPACES=

# Log Correlation
# Header name used for request correlation (e.g., X-Request-ID, X-Correlation-ID)
CORRELATION_HEADER=x-request-id

# Cache settings (seconds)
CACHE_TTL=30

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
